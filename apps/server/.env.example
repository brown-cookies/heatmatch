# ─── Redis ────────────────────────────────────────────────────────────────────
# DEV:  docker Redis spun up automatically by dev.sh — leave this as-is
# PROD: replace with your Upstash Redis URL (rediss://... with SSL)
REDIS_URL=redis://localhost:6379

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# The URL of your frontend — used for CORS and Socket.io origin checks
# DEV:  http://localhost:3000
# PROD: https://yourdomain.com
CLIENT_URL=http://localhost:3000

# ─── Admin dashboard ──────────────────────────────────────────────────────────
# ADMIN_SECRET     → the password you type on the /admin login page
# ADMIN_JWT_SECRET → used to sign the admin session token (min 32 chars)
# ⚠  Change BOTH of these before deploying to production!
ADMIN_SECRET=changeme-admin-password
ADMIN_JWT_SECRET=changeme-jwt-secret-32chars-min
